# ─────────────────────────────────────────────────────────────────────────────
# Bio-SentinelX Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (local dev — zero setup)
DATABASE_URL=sqlite+aiosqlite:///./flood_data.db

# PostgreSQL (Railway / Supabase — comment out SQLite above)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash, no wildcard)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app

# ─── ML Model ────────────────────────────────────────────────────────────────
# Max parallel threads used by sklearn/XGBoost/LightGBM estimators.
# Keep at 2 on cloud free-tier (avoids OOM). Use 4–8 on dedicated hardware.
FLOOD_N_JOBS=2

# ─── Server ──────────────────────────────────────────────────────────────────
# Port the Uvicorn server listens on. Railway overrides this with $PORT automatically.
PORT=8000

# ─── Logging ─────────────────────────────────────────────────────────────────
# One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
