# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./flood_data.db

# PostgreSQL (Railway Postgres plugin — Railway injects this automatically):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8000

# ── Optional: External Data APIs ──────────────────────────────────────────────
# Open-Meteo does not require an API key (free & open)
# SoilGrids REST API does not require a key
# OpenTopoData (public) does not require a key
#
# If you integrate Google Earth Engine for LULC/NDVI, add:
# GOOGLE_EE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_EE_PRIVATE_KEY=path/to/private-key.json
