# ─────────────────────────────────────────────────────────────────────────────
# Bio-SentinelX Frontend — Environment Variables
# Copy to .env in the project root and fill in real values.
# All VITE_ vars are embedded in the client bundle at build time.
# Non-VITE_ vars are consumed by Vite at build time only (not bundled).
# ─────────────────────────────────────────────────────────────────────────────

# ─── AI / LLM Providers ──────────────────────────────────────────────────────
# Google Gemini
GEMINI_API_KEY=

# Groq (ultra-fast inference)
GROQ_API_KEY=

# OpenRouter (multi-model gateway)
OPENROUTER_API_KEY=

# HuggingFace (Inference API)
HF_TOKEN=

# SiliconFlow
SILICONFLOW_API_KEY=

# Cerebras
CEREBRAS_API_KEY=

# Pollinations (image generation)
POLLINATIONS_KEY=

# ─── Data APIs ───────────────────────────────────────────────────────────────
# OpenWeatherMap (current weather)
OPENWEATHER_KEY=

# Mappls / MapMyIndia (Indian geocoding & routing)
VITE_MAPPLS_TOKEN=

# LlamaCloud (document parsing)
LLAMACLOUD_KEY=

# ─── Bio-SentinelX ML Backend ────────────────────────────────────────────────
# URL to the running flood_ml_api FastAPI server
# Local dev: http://localhost:8000
# Production: https://your-railway-app.railway.app
FLOOD_ML_API=http://localhost:8000

# Legacy BioSentinel REST API (if separate from flood_ml_api)
BIOSENTINEL_API=
BIOSENTINEL_API_KEY=

# ─── Database (Supabase) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── Firebase Authentication ─────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─── OAuth / Social Login ────────────────────────────────────────────────────
# GitHub OAuth App Client ID (for provider branding / callback)
VITE_GITHUB_CLIENT_ID=
